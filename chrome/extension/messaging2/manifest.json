{
    "name": "messaging",
    "version": "0.0.1",
    "description": "simple messaging app",
    "content_scripts": [
        {
            "matches": ["http://*/*", "https://*/*"],
            "js": ["page.js"]
        }
    ],
    "browser_action": {
        "default_title": "Time to current page",
        "default_icon": "clock.png",
        "default_popup": "popup.html"
    },
    "manifest_version": 2
}